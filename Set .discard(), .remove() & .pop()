n = int(input())
s = set(map(int, input().split()))
N = int(input())
for _ in range(N):
    command_args = input().split()
    command = command_args[0]  
    if command == 'pop':
        s.pop()
    elif command == 'remove':
        value = int(command_args[1])
        try:
            s.remove(value)
        except KeyError:
            pass 
    elif command == 'discard':
        value = int(command_args[1])
        s.discard(value)
print(sum(s))
