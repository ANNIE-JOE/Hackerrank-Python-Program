import re
import email.utils
def solve():
    try:
        n = int(input())
    except EOFError:
        return
    pattern = r"^[a-zA-Z][\w.-]+@[a-zA-Z]+\.[a-zA-Z]{1,3}$"
    for _ in range(n):
        line = input()
        parsed_name, parsed_email = email.utils.parseaddr(line)
        if re.match(pattern, parsed_email):
            print(line)
if __name__ == '__main__':
    solve()
