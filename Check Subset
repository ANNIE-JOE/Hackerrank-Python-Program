def is_subset(set_a, set_b):
    """Checks if all elements of set_a are present in set_b."""
    for element in set_a:
        if element not in set_b:
            return False
    return True

def solve():
    """Reads input for multiple test cases and checks subset condition."""
    try:
        T = int(input())
        for _ in range(T):
            n_a = int(input())
            set_a = set(map(int, input().split()))
            n_b = int(input())
            set_b = set(map(int, input().split()))
            result = set_a.issubset(set_b)
            print(result)

    except EOFError:
        pass
    except ValueError:
        pass

if __name__ == "__main__":
    solve()
